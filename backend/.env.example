DB_CONNECTION_STRING=
JWT_SECRET=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_URL_ENDPOINT=

# Resend Config for OTP emails
RESEND_API_KEY=
EMAIL_FROM=auth@yourdomain.com

# Login Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# OTP Security
OTP_MAX_ATTEMPTS=5
OTP_BLOCK_MINUTES=5

# Rate Limiting
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_REQUESTS=100
